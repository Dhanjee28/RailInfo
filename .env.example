NODE_ENV=development
PORT=3000

# PostgreSQL — run via docker-compose up
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/irctc_clone"

# Must be at least 32 characters for the zod validation to pass
JWT_SECRET="change_me_to_a_random_32_plus_char_secret"
JWT_EXPIRES_IN=15m

BCRYPT_ROUNDS=10

# Refresh token lifetime in days (Phase 3 auth hardening)
REFRESH_TOKEN_TTL_DAYS=7

# Redis — run via docker-compose up (Phase 3 cache-aside)
REDIS_URL="redis://localhost:6379"
